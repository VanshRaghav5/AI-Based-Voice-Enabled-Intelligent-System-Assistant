# OmniAssist AI local environment variables
#
# Copy this file to `.env` (same folder as this file) and fill values.
# `.env` is ignored by git via .gitignore.
#
# Generate a strong random secret in PowerShell:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# Flask session / CSRF / cookie signing secret
OMNIASSIST_FLASK_SECRET_KEY=

# JWT signing secret used for login sessions
OMNIASSIST_JWT_SECRET=

# Optional: CORS allowed origins (comma-separated)
# OMNIASSIST_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
